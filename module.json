  {
  "id": "chat-tailor",
  "name": "chat-tailor",
  "title": "Chat Tailor",
  "description": "Tailors the Foundry VTT chat for narrative play: styled chitchat (side-talk), a speaker bar with lockable speaker, HTML chat log archiving, and appearance tuning.",
  "version": "1.0.8",
  "compatibility": {
    "minimum": "12",
    "verified": "13"
  },
  "author": "Scheree",
  "authors": [
    {
      "name": "Scheree"
    }
  ],
  "packs": [
    {
      "name": "macros",
      "label": "chat-tailor",
      "path": "packs/macros",
      "type": "Macro"
    }
  ],
  "styles": [  "styles/priv_talk.css", "styles/speaker-bar.css"],
  "relationships": {
    "requires": [{
      "id": "_chatcommands",
      "type": "module",
      "manifest": "https://gitlab.com/woodentavern/foundryvtt-chat-command-lib/-/raw/master/src/module.json",
      "compatibility": { "verified": "2.0.1" }
    }]
  },
    "esmodules": [
      "./scripts/init.js"
    ],
    "scripts": [
      "./lib/jszip.min.js"
    ],
    "languages": [
      {
        "lang": "en",
        "name": "English",
        "path": "languages/en.json"
      },
      {
        "lang": "ko",
        "name": "한국어",
        "path": "languages/ko.json"
      }
  ],
  "url": "https://github.com/JBGeum/chat-tailor",
  "manifest": "https://github.com/JBGeum/chat-tailor/releases/latest/download/module.json",
  "download": "https://github.com/JBGeum/chat-tailor/releases/latest/download/chat-tailor.zip",
  "manifestPlusVersion": "1.2.0"
}